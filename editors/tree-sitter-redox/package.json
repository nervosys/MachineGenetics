{
  "name": "tree-sitter-MechGen",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the MechGen programming language.",
  "repository": {
    "type": "git",
    "url": "https://github.com/nervosys/tree-sitter-MechGen"
  },
  "license": "MIT",
  "main": "bindings/node",
  "keywords": [
    "tree-sitter",
    "parser",
    "MechGen",
    "syntax"
  ],
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.MechGen",
      "file-types": ["rdx"],
      "injection-regex": "^MechGen$"
    }
  ]
}
