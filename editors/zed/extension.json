{
  "id": "MAGE",
  "name": "MAGE",
  "version": "0.1.0",
  "description": "MAGE language support — syntax highlighting and RAP LSP integration.",
  "repository": "https://github.com/nervosys/MAGE",
  "authors": ["nervosys"],
  "lib": {
    "kind": "grammar",
    "grammar": "MAGE"
  },
  "grammars": {
    "MAGE": {
      "repository": "https://github.com/nervosys/tree-sitter-MAGE",
      "rev": "main"
    }
  },
  "languages": {
    "MAGE": {
      "config": {
        "tab_size": 4,
        "hard_tabs": false,
        "line_comment": "// ",
        "block_comment": ["/* ", " */"],
        "brackets": [
          { "start": "{", "end": "}", "close": true, "newline": true },
          { "start": "[", "end": "]", "close": true, "newline": false },
          { "start": "(", "end": ")", "close": true, "newline": false }
        ],
        "autoclose_before": ";:.,=}])>",
        "word_characters": ["_"]
      }
    }
  }
}
