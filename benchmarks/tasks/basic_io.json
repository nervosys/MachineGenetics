  {
    "id": "basic-009",
    "category": "basic-io",
    "difficulty": "simple",
    "task": "Write a function that takes three i32 values and returns the middle value (median of three)",
    "solution": {
      "rdx_source": "+f median3(a: i32, b: i32, c: i32) -> i32 {\n    ? a > b {\n        ? b > c { b } : { ? a > c { c } : { a } }\n    } : {\n        ? a > c { a } : { ? b > c { c } : { b } }\n    }\n}",
      "token_count": 48,
      "effects": [],
      "skb_rules_used": []
    },
    "rust_equivalent": {
      "rs_source": "pub fn median3(a: i32, b: i32, c: i32) -> i32 {\n    if a > b {\n        if b > c { b } else if a > c { c } else { a }\n    } else {\n        if a > c { a } else if b > c { c } else { b }\n    }\n}",
      "token_count": 56
    },
    "tests": [
      { "input": "median3(1, 2, 3)", "expected": "2" },
      { "input": "median3(3, 1, 2)", "expected": "2" },
      { "input": "median3(5, 5, 5)", "expected": "5" }
    ]
  },
