{
  "name": "mechgen-language",
  "displayName": "MechGen Language",
  "description": "Syntax highlighting and RAP integration for the MechGen programming language",
  "version": "0.1.0",
  "publisher": "nervosys",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nervosys/MechGen.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:mechgen"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mechgen",
        "aliases": ["MechGen", "mg"],
        "extensions": [".mg"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mechgen",
        "scopeName": "source.mechgen",
        "path": "./syntaxes/mechgen.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "mechgen.startRap",
        "title": "MechGen: Start RAP Server"
      },
      {
        "command": "mechgen.stopRap",
        "title": "MechGen: Stop RAP Server"
      },
      {
        "command": "mechgen.convertToMechGen",
        "title": "Convert to MechGen (.mg)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .rs",
          "command": "mechgen.convertToMechGen",
          "group": "mechgen"
        }
      ]
    },
    "configuration": {
      "title": "MechGen",
      "properties": {
        "mechgen.rapAddress": {
          "type": "string",
          "default": "127.0.0.1:9876",
          "description": "Address of the RAP (MechGen Agent Protocol) server"
        },
        "mechgen.rapAutoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the RAP server when opening .mg files"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
