# MechGen / MechGen .gitignore

## File system
.DS_Store
desktop.ini

## Editor
*.swp
*.swo
Session.vim
.cproject
.idea
*.iml
.vscode
.project
.vim/
.helix/
.zed/
.favorites.json
.settings/
.vs/
.dir-locals.el

## Tool
.valgrindrc
.cargo

## Build
# Any target/ at any depth — debug binaries/PDBs/dep-files embed absolute
# local paths (machine username), so build output must never be tracked.
**/target/
/build
/dist/

## Run artifacts (regenerable; some embed local paths)
*.ckpt
*.abl
prototype/examples/*.csv

## ICE reports
rustc-ice-*.txt

## Temporary files
*~
\#*
\#*\#
.#*

## Tags
tags
tags.*
TAGS
TAGS.*

## Python
__pycache__/
*.py[cod]
*$py.class

## Node
node_modules
/src/doc/rustc-dev-guide/mermaid.min.js

## Rustdoc GUI tests
tests/rustdoc-gui/src/**.lock

## Test dashboard
.citool-cache/
test-dashboard/

## direnv
/.envrc
/.direnv/

## Environment (secrets)
.env
.env.local
.env.*.local

## nix
/flake.nix
flake.lock
/default.nix

# Before adding new lines, see the comment at the top.
.git.standalone-backup/
RecursiveMachineIntelligence/.git.standalone-backup/
.forge-resolved.mg
