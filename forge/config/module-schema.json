{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forge Module Metadata",
  "description": "Schema for validating Redox Forge module metadata",
  "type": "object",
  "required": ["name", "version", "metadata"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
      "minLength": 1,
      "maxLength": 64,
      "description": "Module name (ASCII alphanumerics, hyphens, underscores)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$",
      "description": "Semantic version (e.g. 1.3.0, 2.0.0-beta.1)"
    },
    "metadata": {
      "type": "object",
      "required": ["description", "license"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Short description of the module"
        },
        "license": {
          "type": "string",
          "description": "SPDX license identifier (e.g. MIT, Apache-2.0)"
        },
        "authors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of authors"
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "Source repository URL"
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 5,
          "description": "Search keywords (max 5)"
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Module categories"
        },
        "edition": {
          "type": "string",
          "enum": ["2025"],
          "description": "Redox language edition"
        },
        "rust_compatibility": {
          "type": "string",
          "description": "Minimum Rust version if transpilable"
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version_req"],
        "properties": {
          "name": { "type": "string" },
          "version_req": { "type": "string" },
          "features": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dev": { "type": "boolean", "default": false },
          "source": {
            "type": "string",
            "enum": ["forge", "crates_io", "git", "path"],
            "default": "forge"
          }
        }
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "methods": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "params": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "return_type": { "type": "string" }
              }
            }
          },
          "builtin": { "type": "boolean", "default": false }
        }
      }
    }
  }
}
