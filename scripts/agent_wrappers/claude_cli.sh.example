#!/usr/bin/env bash
# claude_cli.sh.example — template wrapper that calls Claude Code CLI.
#
# Rename to claude_cli.sh, make executable, and adjust the prompt /
# CLI flags for your environment. The harness only requires that
# stdin = task description, stdout = MAGE source.
#
# Prerequisites:
#   - `claude` (Claude Code CLI) installed and authenticated
#   - The CLI's `-p` (one-shot prompt) flag returns model output on stdout
#
# Usage from repo root (Windows: prefix `bash`):
#   cargo run --bin reliability-bench --manifest-path prototype/Cargo.toml \
#       -- --agent "subprocess:./scripts/agent_wrappers/claude_cli.sh"

set -euo pipefail

TASK=$(cat)

# A focused prompt that asks for raw MAGE source. Keep it short to
# control per-task token cost.
PROMPT="You are writing MAGE code. MAGE uses sigil syntax: \`+f\` = \`pub fn\`,
\`v\` = \`let\`, \`m\` = \`let mut\`, \`?\` = \`match\`, \`?:\` = \`if\`, \`:\` = \`else\`,
\`@\` = \`for in\`, \`@@\` = \`loop\`, \`->\` for return type. Types use sigil
prefixes: \`&T\` ref, \`&!T\` mut-ref, \`@T\` Arc, \`?T\` Option, \`R[T,E]\` Result.
Strings are \`s\`, slices \`[T]\`, Vec \`[T]~\`.

Task: ${TASK}

Reply with raw MAGE source only. No commentary, no markdown fences."

# Single-shot prompt; rely on the CLI to stream the reply to stdout.
# Strip any markdown code fences the model might wrap around output.
claude -p "$PROMPT" \
    | sed -e '/^```/d'
