# Redox OpenTelemetry Configuration
# Copy this file to .env and fill in your credentials.
#
#   cp .env.example .env        # Unix
#   Copy-Item .env.example .env # PowerShell
#
# NEVER commit .env — it is gitignored.

# OTLP exporter endpoint
OTEL_EXPORTER_OTLP_ENDPOINT="https://nervosys.ai/otlp"

# OTLP transport protocol
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"

# Authorization header (replace with your real token)
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer <YOUR_TOKEN_HERE>"

# Service name reported to the telemetry backend
OTEL_SERVICE_NAME="redox-compiler"
