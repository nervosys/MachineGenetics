{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Redox",
  "scopeName": "source.redox",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attributes" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#sigils" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.redox",
          "match": "//.*$"
        },
        {
          "name": "comment.block.redox",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.print.redox",
          "begin": "p\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.redox",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolation.redox",
              "match": "\\{[^}]*\\}"
            }
          ]
        },
        {
          "name": "string.interpolated.redox",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.redox",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolation.redox",
              "match": "\\{[^}]*\\}"
            }
          ]
        },
        {
          "name": "string.quoted.double.redox",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.redox",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.redox",
          "match": "'[^'\\\\]'"
        }
      ]
    },

    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.redox",
          "match": "@(d|i|i!|cfg|test|allow|async|inline)\\b",
          "captures": {
            "0": { "name": "keyword.other.attribute.redox" }
          }
        },
        {
          "name": "meta.attribute.args.redox",
          "begin": "@(d|cfg|allow)\\(",
          "end": "\\)",
          "beginCaptures": {
            "0": { "name": "keyword.other.attribute.redox" }
          },
          "patterns": [
            {
              "name": "entity.name.type.redox",
              "match": "[A-Za-z_][A-Za-z0-9_]*"
            }
          ]
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "comment": "Public function declaration: +f name",
          "match": "(\\+f)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.function.redox" }
          }
        },
        {
          "comment": "Crate function declaration: ~f name",
          "match": "(~f)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.function.redox" }
          }
        },
        {
          "comment": "Async function declaration: af name",
          "match": "(af)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.function.redox" }
          }
        },
        {
          "comment": "Private function declaration: f name",
          "match": "\\b(f)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.function.redox" }
          }
        },
        {
          "comment": "Public struct: +S Name",
          "match": "(\\+S)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.type.redox" }
          }
        },
        {
          "comment": "Struct: S Name",
          "match": "\\b(S)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.type.redox" }
          }
        },
        {
          "comment": "Public enum: +E Name",
          "match": "(\\+E)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.type.redox" }
          }
        },
        {
          "comment": "Enum: E Name",
          "match": "\\b(E)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.type.redox" }
          }
        },
        {
          "comment": "Public trait: +T Name",
          "match": "(\\+T)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.type.redox" }
          }
        },
        {
          "comment": "Trait: T Name",
          "match": "\\b(T)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.type.redox" }
          }
        },
        {
          "comment": "Impl: I Type",
          "match": "\\b(I)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.type.redox" }
          }
        },
        {
          "comment": "Module: M name / +M name",
          "match": "(\\+?M)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.namespace.redox" }
          }
        },
        {
          "comment": "Use: u path",
          "match": "\\b(u)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "entity.name.namespace.redox" }
          }
        },
        {
          "comment": "Variable binding: v name",
          "match": "\\b(v)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "variable.other.redox" }
          }
        },
        {
          "comment": "Mutable binding: m name",
          "match": "\\b(m)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "variable.other.mutable.redox" }
          }
        },
        {
          "comment": "Constant: c NAME / +c NAME",
          "match": "(\\+?c)\\s+([A-Z_][A-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.redox" },
            "2": { "name": "constant.other.redox" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.redox",
          "match": "\\b(loop|break|continue|ret|yield|for|while|in)\\b"
        },
        {
          "name": "keyword.other.redox",
          "match": "\\b(effect|handle|spec|type|static|self|Self|super|crate|as|where|move|unsafe|extern|dyn)\\b"
        },
        {
          "name": "constant.language.boolean.redox",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.redox",
          "match": "\\b(None|Some|Ok|Err)\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.redox",
          "match": "=>|->|<-"
        },
        {
          "name": "keyword.operator.comparison.redox",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.redox",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.redox",
          "match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|="
        },
        {
          "name": "keyword.operator.arithmetic.redox",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.redox",
          "match": "&|\\||\\^|<<|>>"
        },
        {
          "name": "keyword.operator.range.redox",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.question.redox",
          "match": "\\?"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.redox",
          "match": "\\b(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|char|s|str|never)\\b"
        },
        {
          "name": "entity.name.type.redox",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.redox",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?(f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.hex.redox",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.octal.redox",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.binary.redox",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.integer.redox",
          "match": "\\b[0-9][0-9_]*(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize)?\\b"
        }
      ]
    },

    "sigils": {
      "patterns": [
        {
          "name": "punctuation.sigil.owned.redox",
          "match": "\\^"
        },
        {
          "name": "punctuation.sigil.rc.redox",
          "match": "\\$"
        },
        {
          "name": "punctuation.sigil.arc.redox",
          "match": "@(?![a-zA-Z])"
        },
        {
          "name": "punctuation.sigil.vec.redox",
          "match": "~"
        },
        {
          "name": "storage.modifier.visibility.redox",
          "match": "\\+"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.redox",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
